model Folder {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  owner        User     @relation(fields: [ownerId], references: [id])
  ownerId      Int      @map("owner_id")
  parentFolder Folder?  @relation("ParentFolder", fields: [parentId], references: [id], onDelete: Cascade)
  childFolders Folder[] @relation("ParentFolder")
  parentId     String?  @map("parent_id") @db.Uuid
  files        File[]

  @@unique([ownerId, parentId, name])
}

model File {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayName String   @map("display_name")
  owner       User     @relation(fields: [ownerId], references: [id])
  ownerId     Int      @map("owner_id")
  folder      Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  folderId    String?  @map("folder_id") @db.Uuid
  size        BigInt   @default(0)
  mimeType    String   @map("mime_type")
  fileName    String   @map("file_name")
  destination String   @map("file_path")
  uploadedAt  DateTime @default(now()) @map("uploaded_at") @db.Timestamptz()
}
